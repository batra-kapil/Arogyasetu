    <assignments>
        <name>Assign_Cancel_Message</name>
        <label>Assign Cancel Message</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>CancelMessage</assignToReference>
            <operator>Assign</operator>
            <value>
                <stringValue>Your appointment has been successfully cancelled.</stringValue>
            </value>
        </assignmentItems>
    </assignments>
    <decisions>
        <name>Check_if_appointment_Exist</name>
        <label>Check if appointment Exist</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>No</defaultConnectorLabel>
        <rules>
            <name>Yes</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_Appointment</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_Appointment</targetReference>
            </connector>
            <label>Yes</label>
        </rules>
    </decisions>
    <environments>Default</environments>
    <interviewLabel>Cancel Appointment {!$Flow.CurrentDateTime}</interviewLabel>
