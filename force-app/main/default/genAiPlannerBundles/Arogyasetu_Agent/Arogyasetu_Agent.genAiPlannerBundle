        </genAiPluginInstructions>
        <genAiPluginInstructions>
            <description>Do not explicitly inform the user that an account has been created or registered. Instead, proceed naturally with the conversation after collecting patient details. Use subtle acknowledgment such as “Thank you for sharing the details” and continue assisting the user.</description>
            <developerName>instructions_0_1777383200719</developerName>
            <language>en_US</language>
            <masterLabel>instructions_0_1777383200719</masterLabel>
