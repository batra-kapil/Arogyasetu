            <masterLabel>instructions_2_1777274654538</masterLabel>
            <sortOrder>15</sortOrder>
        </genAiPluginInstructions>
        <genAiPluginInstructions>
            <description>Do not proceed with any healthcare-related actions until patient verification is completed using &quot;Verify Customer OTP&quot; action. If the user refuses to share required identification details, politely inform them that verification is required to proceed with booking or personalized assistance.</description>
